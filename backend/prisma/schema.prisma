generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model OtpCode {
  id          String   @id @default(uuid())
  phoneNumber String   @unique 
  code        String
  expiresAt   DateTime 
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

// Tüketici (Consumer) modeli (OTP ile kimlik doğrulama)
model User {
  id        String    @id @default(uuid())
  phone     String    @unique
  email     String?   @unique
  name      String?
  surname   String?
  role      String    @default("user")
  createdAt DateTime  @default(now())
  lastLogin DateTime  @default(now())
  
  // Tüketici İlişkileri
  addresses    Address[]
  orders       Order[]
  deviceTokens DeviceToken[]
  favoriteProducts FavoriteProduct[]
  favoriteShops    FavoriteShop[]
  reviews          Review[]
}


// Merchant (satıcı) hesap durumu
enum MerchantStatus {
  PENDING   
  ACTIVE    
  REVISION  
  REJECTED  
  ON_HOLD   
}

enum ShopType {
  RESTAURANT
  MARKET
  WATER
  FLOWER
  GREENGROCER
  BUTCHER
  OTHER
}

// İşletme Başvurusu / Satıcı Yöneticisi modeli
model Merchant {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String
  businessName     String
  msNumber         String?        // Şirket Kayıt Numarası
  taxNumber        String?        // Vergi Numarası
  phone            String?
  district         String?
  fullAddress      String?
  status           MerchantStatus @default(PENDING)
  revisionMessage  String?        // Yönetici tarafından revizyon notu
  businessId       String?        // Geriye dönük destek: Eski işleyişteki auth linki
  role             String         @default("merchant")
  
  ownerFirstName   String         @default("")
  ownerLastName    String         @default("")
  ownerPhone       String         @default("")
  businessPhone    String         @default("")
  merchantType     ShopType       @default(OTHER)
  subType          String?
  hasHardware      Boolean        @default(false)
  agreedToTerms    Boolean        @default(false)
  identityNumber   String?
  countryCode      String         @default("TR")

  createdAt        DateTime       @default(now())
  lastLogin        DateTime       @default(now())
  
  // Merchant İlişkileri (Bir satıcının onaylandığında 1 dükkanı olur)
  shop             Shop?
  deviceTokens     DeviceToken[]

  @@index([email])
  @@index([status])
}

// ------------------------------------------------------------------
// PAZAR YERİ KÜMELERİ (DOMAIN DATA MODELS)
// ------------------------------------------------------------------

// Dükkan (Shop)
model Shop {
  id               String    @id @default(uuid())
  merchantId       String    @unique // 1-1 İlişki (Bir merchant'ın bir mağazası var)
  merchant         Merchant  @relation(fields: [merchantId], references: [id])
  name             String
  description      String?
  address          String?
  taxNumber        String?
  isActive         Boolean   @default(false) // Dükkan açık/kapalı veya aktif/pasif mi
  imageUrl         String?   // Dükkan logosu
  headerImageUrl   String?   // Dükkan kapak resmi
  type             ShopType  @default(OTHER)
  
  // Lokasyon ve Mesafe
  latitude         Float?
  longitude        Float?
  deliveryRadiusKm Float     @default(5.0)
  deliveryPolygon  Json?     // Özel Teslimat Bölgesi (Poligon koordinatları)

  // Çalışma Saatleri ve Finansal
  workingHours          Json?
  deliveryTime          String?               // Örn: "30-45 dk"
  minOrderAmount        Decimal               @db.Decimal(10, 2) @default(150.0)
  minimumOrderAmount    Float                 @default(150.0)
  deliveryPricingType   DeliveryPricingType   @default(FIXED)
  baseDeliveryFee       Float                 @default(30.0)
  deliveryFeePerKm      Float                 @default(5.0)
  freeDeliveryThreshold Float?
  
  products         Product[]
  orders           Order[]
  favoriteShops    FavoriteShop[]
  averageRating    Float     @default(5.0) // Cache alan: Puan ortalaması
  reviewCount      Int       @default(0)   // Cache alan: Toplam yorum sayısı
  reviews          Review[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// 1. Birimler Tablosu (Localization Destekli)
model Unit {
  id             String          @id @default(uuid())
  code           String          @unique // Örn: "ADET", "KG", "LITRE", "PAKET"
  nameTr         String          // Örn: "Adet"
  nameEn         String          // Örn: "Pieces"
  globalProducts GlobalProduct[]
  products       Product[]
}

// 2. Birleştirilmiş Tekil İlişkisel Kategori Tablosu (Self-Referential - Adjacency List Tree)
model Category {
  id             String          @id // Migros JSON ID'si string olarak tutulacaktır
  name           String
  shopType       String          @default("MARKET") // RESTAURANT, MARKET, GREENGROCER, BUTCHER
  imageUrl       String?         // Migros CDN stüdyo görselleri
  color          String?         // Kategori kart rengi (Örn: #FFE8E1)
  
  // Kendi kendine ilişki (Self-Referential Relation)
  parentId       String?
  parent         Category?       @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Cascade)
  children       Category[]      @relation("CategoryToCategory")

  globalProducts GlobalProduct[]
  products       Product[]

  @@index([parentId])
}

// 3. Markalar Tablosu
model Brand {
  id             String          @id @default(uuid())
  name           String          @unique // Örn: "Coca-Cola", "Ülker", "Eti", "Koop"
  logoUrl        String?         
  globalProducts GlobalProduct[]
  products       Product[]
}

// 4. Global Ürün Kütüphanesi (Master Catalog)
model GlobalProduct {
  id              String          @id @default(uuid())
  barcode         String?         @unique
  sku             String?         @unique // Migros SKU kodu (Örn: "05040812")
  name            String
  prettyName      String?         // URL ve SEO dostu isim (Örn: "sma-optipro-probiyotik-p-4ceaac")
  imageUrl        String          // Profesyonel stüdyo resmi
  description     String?         @db.Text // HTML formatlı zengin ürün açıklamaları
  minQuantity     Float           @default(1.0)
  stepSize        Float           @default(1.0)
  
  // Fiyatlandırma ve İndirim Mimarisi (Katalog Standartı)
  regularPrice    Decimal?        @db.Decimal(10, 2) // Normal satış fiyatı
  shownPrice      Decimal?        @db.Decimal(10, 2) // İndirimli/Yansıyan fiyat
  discountRate    Int             @default(0)        // İndirim oranı (Örn: 25 -> %25 indirim)

  // İlişkiler (Normalizasyon)
  unitId          String
  unit            Unit            @relation(fields: [unitId], references: [id])
  brandId         String?
  brand           Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categoryId      String
  category        Category        @relation(fields: [categoryId], references: [id])

  // Alt/Çocuk dükkan ürünleri ilişkisi
  childProducts   Product[]

  @@index([unitId])
  @@index([brandId])
  @@index([categoryId])
}

// 5. Satıştaki Aktif Dükkan Ürünleri
model Product {
  id              String      @id @default(uuid())
  shopId          String
  shop            Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  
  // Dükkan seviyesinde indirim desteği
  regularPrice    Decimal     @db.Decimal(10, 2) // Üstü çizili fiyat (Normal fiyat)
  price           Decimal     @db.Decimal(10, 2) // 🚨 shownPrice: Müşterinin ödeyeceği aktif fiyat
  discountRate    Int         @default(0)        // Dükkan özel indirim yüzdesi
  
  imageUrl        String?
  isActive        Boolean     @default(true)
  
  minQuantity     Float       @default(1.0)
  stepSize        Float       @default(1.0)
  
  // Stoksuz/Sınırsız Satış Desteği
  trackStock      Boolean     @default(false)  // Varsayılan false: Stok adedi takip edilmez, hep "Stokta" kabul edilir.

  // Polymorphic / Dynamic Fields
  barcode         String?
  stockQuantity   Int?        @default(0)
  weightOrVolume  String?
  preparationTime Int?
  hasDeposit      Boolean?    @default(false)
  depositPrice    Float?

  // Master kütüphane bağlantısı (Inheritance)
  globalProductId String?
  globalProduct   GlobalProduct? @relation(fields: [globalProductId], references: [id], onDelete: SetNull)

  // İlişkiler (Sorgu performansları ve bağımsız özel ürünler için)
  unitId         String
  unit           Unit            @relation(fields: [unitId], references: [id])
  brandId        String?
  brand          Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id])

  orderItems      OrderItem[]
  favoriteProducts FavoriteProduct[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([shopId])
  @@index([globalProductId])
  @@index([unitId])
  @@index([brandId])
  @@index([categoryId])
}

// Tüketici Adresi
model Address {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String   // Örn: Ev, İş
  fullAddress String
  city        String?
  district    String?
  latitude    Float?
  longitude   Float?
  
  orders      Order[]

  isDeleted   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Sipariş Durumları
enum OrderStatus {
  PENDING
  PREPARING
  ON_THE_WAY
  READY_FOR_PICKUP
  DELIVERED
  CANCELLED
}

// Tüketicinin Shop'tan Verdiği Sipariş
model Order {
  id              String      @id @default(uuid())
  consumerId      String
  consumer        User        @relation(fields: [consumerId], references: [id])
  shopId          String
  shop            Shop        @relation(fields: [shopId], references: [id])
  addressId       String
  address         Address     @relation(fields: [addressId], references: [id])
  
  deliveryAddress String      @default("")
  totalAmount     Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @db.Decimal(10, 2) @default(0)
  status          OrderStatus @default(PENDING)
  customerNote    String?     // Müşterinin sipariş veya kurye için ekleyeceği not
  
  paymentMethod   PaymentMethod @default(CASH_ON_DELIVERY)
  paymentStatus   PaymentStatus @default(PENDING)
  
  cancelReason    String?
  cancelledAt     DateTime?
  cancelledBy     String?
  
  items           OrderItem[]
  paymentTransactions PaymentTransaction[]
  
  courierId       String?
  courier         Courier?    @relation(fields: [courierId], references: [id])
  estimatedDeliveryDuration Int?

  dontRingBell    Boolean     @default(false)
  leaveAtDoor     Boolean     @default(false)
  review          Review?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// Sipariş Kalemleri
model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  quantity    Float
  unitPrice   Decimal  @db.Decimal(10, 2)
}

// Ödeme Yöntemleri
enum PaymentMethod {
  CASH_ON_DELIVERY
  CARD_ON_DELIVERY
  ONLINE_PAYMENT
}

// Ödeme Durumları
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// Para Birimleri
enum Currency {
  TRY
  GBP
  EUR
  USD
}

enum DeliveryPricingType {
  FIXED
  DISTANCE_BASED
}

enum CampaignType {
  FREE_DELIVERY_FIRST_ORDERS
  PERCENTAGE_DISCOUNT
  FIXED_AMOUNT_DISCOUNT
}

// Ödeme İşlemleri / Logları
model PaymentTransaction {
  id             String        @id @default(uuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id])
  
  amount         Decimal       @db.Decimal(10, 2)
  currency       Currency      @default(TRY)
  exchangeRate   Decimal?      @db.Decimal(10, 4) // Eğer kur çevrimi varsa
  
  provider       String        // Örn: "iyzico", "stripe", "cash"
  routingType    String?       // Hangi kurala göre seçildi (örn: "BIN_BASED", "LEAST_COST")
  status         PaymentStatus @default(PENDING)
  providerTxId   String?       // Sağlayıcı tarafındaki işlem numarası
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([orderId])
}

// ------------------------------------------------------------------
// KAMPANYA VE İNDİRİMLER (CAMPAIGN DATA MODELS)
// ------------------------------------------------------------------

model Campaign {
  id              String          @id @default(uuid())
  title           String          
  description     String          @db.Text
  prettyName      String?         // SEO dostu kampanya ismi
  imageUrl        String          // Anasayfadaki geniş banner görseli
  type            String          @default("SYSTEM") // SYSTEM, FREE_DELIVERY, PERCENTAGE_DISCOUNT
  isActive        Boolean         @default(true)
  maxUsesPerUser  Int             @default(5)
  finishDate      DateTime?       // Milisaniye timestamp'ten parse edilecek bitiş tarihi
  createdAt       DateTime        @default(now())
}

// Cihaz Bildirim Token'ları (FCM vb. için)
model DeviceToken {
  id         String    @id @default(uuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantId String?
  merchant   Merchant? @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  token      String    @unique
  platform   String   // "ANDROID", "IOS", "WEB"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([merchantId])
}

model Courier {
  id           String           @id @default(uuid())
  name         String
  phoneNumber  String           @unique
  vehiclePlate String?
  isActive     Boolean          @default(true)
  locations    CourierLocation[]
  orders       Order[]
}

model CourierLocation {
  id        String   @id @default(uuid())
  courierId String   @unique
  courier   Courier  @relation(fields: [courierId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  bearing   Float    @default(0.0)
  updatedAt DateTime @updatedAt

  @@index([courierId])
}

// 1. Favori Ürünler Tablosu (Kullanıcı bazlı ürün hızlı erişimi)
model FavoriteProduct {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// 2. Favori İşletmeler Tablosu (Kullanıcı bazlı dükkan hızlı erişimi)
model FavoriteShop {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, shopId])
  @@index([userId])
  @@index([shopId])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?  @db.VarChar(500)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([userId])
}

